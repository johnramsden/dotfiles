{
  "permissions": {
    "allow": [
      "Bash(multipass info*)",
      "Bash(multipass exec *)",
      "Bash(multipass start *)",
      "Bash(git config user.name)",
      "Bash(git config user.email)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh release:*)",
      "Bash(git remote get-url origin)"
    ],
    "deny": [
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh pr edit *)",
      "Bash(gh issue close *)",
      "Bash(gh release create *)",
      "Bash(gh release delete *)"
    ],
    "additionalDirectories": [
      "~/Canonical/Ceph/Docs/Ceph/",
      "~/Workspace/vault/"
    ]
  },
  "model": "opus[1m]",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude needs input 💬'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude done ❇'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/john/.local/bin/statusline.sh"
  },
  "enabledPlugins": {
    "gitkraken-hooks@gitkraken": true
  },
  "extraKnownMarketplaces": {
    "gitkraken": {
      "source": {
        "source": "directory",
        "path": "/home/john/.claude/plugins/marketplaces/gitkraken"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "voiceEnabled": false
}
